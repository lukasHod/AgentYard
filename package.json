{
  "name": "agentyard",
  "version": "0.0.1",
  "description": "Gamified agent orchestrator — a sci-fi shipyard for managing development workflows across many projects.",
  "type": "module",
  "bin": {
    "agentyard": "dist/server/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node --import tsx scripts/dev.ts",
    "dev:watch": "node --import tsx scripts/dev.ts --watch",
    "dev:server": "node --import tsx src/server/cli.ts start --dev",
    "dev:server:watch": "node --import tsx --watch src/server/cli.ts start --dev",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsup",
    "start": "node dist/server/cli.js start",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:server && npm run test:client",
    "test:server": "node --import tsx --test \"src/core/executor.test.ts\" \"src/core/plugins.test.ts\" \"src/core/tools.test.ts\" \"src/server/runtime/scriptArgv.test.ts\" \"src/server/runtime/markCompleteGate.test.ts\" \"src/server/runtime/TerminalSessionManager.test.ts\" \"src/server/runtime/adapters/claudeSdk.test.ts\" \"src/server/runtime/adapters/registry.test.ts\" \"src/server/runtime/reconcile.test.ts\" \"src/server/routes/browseFolder.test.ts\" \"src/server/runState.test.ts\" \"src/server/runStore.test.ts\" \"src/server/scm/githubScm.test.ts\" \"src/server/tools/crud.test.ts\" \"src/server/tools/lifecycle.test.ts\" \"src/server/tools/resolver.test.ts\" \"src/server/tools/scanCache.test.ts\" \"src/server/workflows.test.ts\" \"src/server/planets.test.ts\"",
    "test:client": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.144",
    "@fastify/static": "^7.0.4",
    "@lydell/node-pty": "^1.1.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "better-sqlite3": "^11.5.0",
    "commander": "^12.1.0",
    "fastify": "^4.28.1",
    "js-yaml": "^4.1.1",
    "open": "^10.1.0",
    "simple-git": "^3.27.0",
    "socket.io": "^4.8.1",
    "three": "^0.166.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-three/test-renderer": "^8.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/howler": "^2.2.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/ui": "^4.1.7",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "howler": "^2.2.4",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^3.4.13",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^4.1.7",
    "zustand": "^5.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
